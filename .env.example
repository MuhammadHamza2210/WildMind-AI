# ─────────────────────────────────────────────────────────────
# SERVER-SIDE secrets — NO "VITE_" prefix, so they never reach the
# browser. Read only by the Express proxy in server/index.js.
# ─────────────────────────────────────────────────────────────

# Pexels (animal images) — https://www.pexels.com/api/
PEXELS_API_KEY=your_pexels_api_key_here

# Google AI Studio (Gemini) — https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional server overrides
# GEMINI_MODEL=gemini-flash-latest
# PORT=3001

# ─────────────────────────────────────────────────────────────
# Client (browser) settings — safe to expose. "VITE_" prefix required.
# ─────────────────────────────────────────────────────────────
# Force a backend: 'gemini' (default, via proxy) or 'ollama' (local only)
# VITE_AI_PROVIDER=gemini
